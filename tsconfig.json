{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["esnext"],
    "module": "node16",
    "moduleResolution": "node16",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2018",
    "types": ["jest", "node"]
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
